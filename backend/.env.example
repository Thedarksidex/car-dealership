DB_HOST=localhost
DB_PORT=5432
DB_NAME=maruti_dealership
DB_USER=postgres
DB_PASSWORD=your_password_here

JWT_SECRET=maruti_dealership_secret_key_change_in_production
JWT_EXPIRES_IN=7d

PORT=5000

# ── PostgreSQL (Render / production) ─────────────────────────
# Render provides this automatically. When set, individual
# DB_* vars above are ignored.
DATABASE_URL=

# ── Email (Nodemailer) ───────────────────────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of extra allowed origins
ALLOWED_ORIGINS=https://your-site.netlify.app
