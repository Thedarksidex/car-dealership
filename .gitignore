# ── Node ────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── Environment variables (never commit secrets) ─────────────────────────────
.env
.env.*
!.env.example

# ── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ── OS generated files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── VS Code ──────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json

# ── Generated files ──────────────────────────────────────────────────────────
Maruti_Dealership_Project_Documentation.docx
generate-docs.js

# ── Uploaded / user images (keep folder, ignore contents) ───────────────────
frontend/images/*
!frontend/images/.gitkeep
